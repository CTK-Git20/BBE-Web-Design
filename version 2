    </section>

    <!-- Optimized White Tech Terminal -->
    <section class="pb-32 bg-white px-6">
        <div class="max-w-4xl mx-auto">
            <div class="reveal animate-float relative">
                <!-- Inner Glow for White Tech Look -->
                <div class="absolute -inset-4 bg-primary/5 blur-2xl rounded-3xl"></div>
                
                <div class="relative bg-white rounded-2xl overflow-hidden soft-shadow border border-primary/20">
                    <!-- Terminal Header (White Theme) -->
                    <div class="bg-ghost px-6 py-4 flex items-center justify-between border-b border-black/5">
                        <div class="flex space-x-1.5">
                            <div class="w-2.5 h-2.5 rounded-full bg-slate/20"></div>
