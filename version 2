<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bubbleye Poseidon | World's First AI Agent for Creative Automation</title>
    
    <meta name="description" content="Bubbleye Poseidon: The central AI Orchestration Hub for Meta, Google, TikTok, and more. Precise automation with native API preservation.">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#007AFF',
                        deep: '#0F172A',
                        ghost: '#F8FAFC',
                        slate: '#475569',
                    },
                    animation: {
                        'text-shimmer': 'text-shimmer 3s linear infinite',
                        'float': 'float 6s ease-in-out infinite',
                    },
                    keyframes: {
                        'text-shimmer': {
                            '0%': { 'background-position': '0% 50%' },
                            '100%': { 'background-position': '200% 50%' },
                        },
                        'float': {
                            '0%, 100%': { transform: 'translateY(0px)' },
                            '50%': { transform: 'translateY(-10px)' },
                        }
                    }
                }
            }
        }
    </script>

    <style>
        body { font-family: 'Inter', sans-serif; background-color: #FFFFFF; color: #0F172A; }
        .mono { font-family: 'JetBrains Mono', monospace; }
        
        .soft-shadow { box-shadow: 0 30px 60px rgba(0, 0, 0, 0.05); }
        .glass-nav { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
        
        .premium-border { border: 1px solid rgba(0,0,0,0.06); }
        
        .hover-card {
            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .hover-card:hover {
            border-color: #007AFF;
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0, 122, 255, 0.1);
        }

        .gradient-tech {
            background: linear-gradient(to right, #007AFF 0%, #60A5FA 50%, #007AFF 100%);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: text-shimmer 4s linear infinite;
        }

        .cursor {
            display: inline-block;
            width: 8px;
            height: 1.2em;
            background: #007AFF;
            margin-left: 4px;
            vertical-align: middle;
            animation: blink 0.8s infinite;
        }
        @keyframes blink { 50% { opacity: 0; } }

        .reveal { opacity: 0; transform: translateY(20px); transition: all 0.8s ease-out; }
        .reveal.active { opacity: 1; transform: translateY(0); }

        .btn-pulse { position: relative; }
        .btn-pulse::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            border-radius: 12px;
            border: 2px solid #007AFF;
            animation: pulse-ring 2.5s infinite;
            pointer-events: none;
        }
        @keyframes pulse-ring {
            0% { transform: scale(1); opacity: 0.6; }
            100% { transform: scale(1.4); opacity: 0; }
        }

        /* Light Tech Terminal Background */
        .tech-grid {
            background-image: radial-gradient(rgba(0, 122, 255, 0.05) 1px, transparent 0);
            background-size: 24px 24px;
        }
    </style>
</head>
<body class="antialiased overflow-x-hidden">

    <!-- Navigation -->
