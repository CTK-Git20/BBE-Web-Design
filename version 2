                <p class="text-slate text-lg max-w-2xl mx-auto leading-relaxed">Three distinct operational frameworks designed for every professional workflow.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-10">
                <div class="reveal bg-white p-12 rounded-[3.5rem] premium-border hover-card group">
                    <div class="w-20 h-20 bg-primary text-white rounded-3xl flex items-center justify-center mb-10 shadow-2xl shadow-primary/25">
                        <i data-lucide="bot" class="w-10 h-10"></i>
                    </div>
                    <h3 class="text-2xl font-extrabold mb-4">Agent-Led</h3>
                    <p class="text-slate text-sm leading-relaxed">Natural Language Command. Describe your campaign and let the AI handle cross-network deployment.</p>
                </div>
                <div class="reveal bg-white p-12 rounded-[3.5rem] premium-border hover-card group" style="transition-delay: 100ms;">
                    <div class="w-20 h-20 bg-deep text-white rounded-3xl flex items-center justify-center mb-10">
                        <i data-lucide="code-2" class="w-10 h-10"></i>
                    </div>
                    <h3 class="text-2xl font-extrabold mb-4">Developer-First</h3>
                    <p class="text-slate text-sm leading-relaxed">Programmatic control via robust API endpoints. Build custom logic on top of Poseidon's core.</p>
                </div>
                <div class="reveal bg-white p-12 rounded-[3.5rem] premium-border hover-card group" style="transition-delay: 200ms;">
                    <div class="w-20 h-20 bg-primary/10 text-primary rounded-3xl flex items-center justify-center mb-10">
                        <i data-lucide="layout-dashboard" class="w-10 h-10"></i>
                    </div>
                    <h3 class="text-2xl font-extrabold mb-4">Manager-Friendly</h3>
                    <p class="text-slate text-sm leading-relaxed">The Unified Dashboard. View every asset's lifecycle across global networks from a single cockpit.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Center CTA -->
    <section class="py-40 bg-white px-6">
        <div class="reveal max-w-5xl mx-auto bg-deep rounded-[4rem] p-16 md:p-32 text-center relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 pointer-events-none">
                <svg width="100%" height="100%"><pattern id="grid-pattern" width="60" height="60" patternUnits="userSpaceOnUse"><path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5"/></pattern><rect width="100%" height="100%" fill="url(#grid-pattern)" /></svg>
            </div>
            
            <h2 class="text-5xl md:text-7xl font-extrabold text-white mb-10 relative z-10 tracking-tight">Request Access <br/>to the Future.</h2>
            <div class="flex justify-center relative z-10">
                <button class="bg-primary text-white px-16 py-6 rounded-2xl font-extrabold text-xl hover:bg-blue-600 hover:scale-105 transition-all shadow-2xl shadow-primary/30">
                    Book a Live Demo
                </button>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-white border-t border-black/5 py-24 px-6 text-center md:text-left">
        <div class="max-w-7xl mx-auto grid md:grid-cols-4 gap-16">
            <div class="col-span-2">
                <span class="text-2xl font-black text-deep tracking-tighter uppercase">Bubbleye Poseidon</span>
                <p class="mt-6 text-slate text-sm max-w-xs leading-relaxed opacity-60 mx-auto md:mx-0">
                    The orchestration layer for the AI age. Unifying global networks into a single autonomous command center.
                </p>
            </div>
            <div>
                <h4 class="font-bold text-deep mb-8 uppercase text-xs tracking-[0.2em] opacity-40">Documentation</h4>
                <ul class="text-slate text-sm space-y-4 font-semibold">
                    <li><a href="#" class="hover:text-primary transition-colors">API Modules</a></li>
                    <li><a href="#" class="hover:text-primary transition-colors">Platform Status</a></li>
                </ul>
            </div>
            <div>
                <h4 class="font-bold text-deep mb-8 uppercase text-xs tracking-[0.2em] opacity-40">Connect</h4>
                <ul class="text-slate text-sm space-y-4 font-semibold">
                    <li><a href="#" class="hover:text-primary transition-colors">Contact Sales</a></li>
                    <li><a href="#" class="hover:text-primary transition-colors">LinkedIn</a></li>
                </ul>
            </div>
        </div>
        <div class="max-w-7xl mx-auto mt-24 pt-10 border-t border-black/5 text-center">
            <p class="text-slate/30 text-[11px] font-bold uppercase tracking-[0.4em]">
                © 2026 Bubbleye AI. Built for the future of Ad Orchestration.
            </p>
        </div>
    </footer>

    <script>
        lucide.createIcons();

        // 1. Module Generator
        const modules = [
            { name: "Applovin", icon: "zap" },
            { name: "Google Ads", icon: "search" },
            { name: "Ironsource", icon: "cpu" },
            { name: "Meta", icon: "facebook" },
            { name: "TikTok", icon: "music" },
            { name: "Mintegral", icon: "layers" },
            { name: "Moloco", icon: "bar-chart-2" },
            { name: "Unity", icon: "box" }
        ];

        const moduleGrid = document.getElementById('module-grid');
        modules.forEach((mod, idx) => {
            const div = document.createElement('div');
            div.className = "reveal bg-white p-6 rounded-2xl flex flex-col items-center justify-center premium-border hover-card group cursor-default";
            div.style.transitionDelay = `${idx * 40}ms`;
            div.innerHTML = `
                <div class="text-slate/30 group-hover:text-primary transition-colors mb-4"><i data-lucide="${mod.icon}" class="w-6 h-6"></i></div>
                <span class="text-[11px] font-black uppercase tracking-widest text-deep opacity-80">${mod.name}</span>
            `;
            moduleGrid.appendChild(div);
        });
        lucide.createIcons();

        // 2. Scroll Observer
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        // 3. Fast White AI Terminal (No Chinese Localisation)
        const term = document.getElementById('terminal-engine');
        const tasks = [
            {
                prompt: "poseidon sync --top-assets --from meta --to google,unity",
                logs: [
                    ">> Scanning Meta native asset library...",
                    ">> Authenticating Hub: Google & Unity modules...",
                    ">> Analyzing CTR/ROAS performance metrics...",
                    ">> Syncing VID_PROMO_V2 to global networks...",
                    ">> SUCCESS: Orchestration active."
                ]
            },
            {
                prompt: "poseidon optimize --network tiktok --localize DE",
                logs: [
                    ">> Mapping script tokens to German (Neural V4)...",
                    ">> Rendering localized TikTok metadata...",
                    ">> Deploying to Berlin Native Hub...",
                    ">> SUCCESS: Localized variation active."
                ]
            }
        ];

        let currentIdx = 0;
        async function runTerminal() {
            term.innerHTML = '';
            const task = tasks[currentIdx];

            const p = document.createElement('div');
            p.className = "text-deep mb-6 flex items-center";
            p.innerHTML = `<span class="text-primary mr-5 font-black">➜</span><span id="typing-box"></span><span class="cursor"></span>`;
            term.appendChild(p);

            const box = document.getElementById('typing-box');
            for(let char of task.prompt) {
                box.textContent += char;
                await new Promise(r => setTimeout(r, 20));
            }

            await new Promise(r => setTimeout(r, 400));

            for(let log of task.logs) {
                const logLine = document.createElement('div');
                const ok = log.includes("SUCCESS");
                
                // ISO English Timestamp (No Chinese characters like 下午)
                const time = new Date().toLocaleTimeString('en-GB', { hour12: false });
                
                logLine.className = `text-[11px] mb-2.5 opacity-0 transition-opacity duration-150 ${ok ? 'text-primary font-black pt-6' : 'text-slate/60'}`;
                logLine.innerHTML = `<span class="mr-5 opacity-30 text-[9px]">${time}</span> ${log}`;
                term.appendChild(logLine);
                
                void logLine.offsetWidth;
                logLine.style.opacity = '1';
                await new Promise(r => setTimeout(r, 100));
            }

            await new Promise(r => setTimeout(r, 4500));
            currentIdx = (currentIdx + 1) % tasks.length;
            runTerminal();
        }
        runTerminal();
    </script>
</body>
</html>
