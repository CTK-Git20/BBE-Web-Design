                            <div class="w-2.5 h-2.5 rounded-full bg-slate/20"></div>
                        </div>
                        <div class="mono text-[10px] text-primary font-bold tracking-widest uppercase">poseidon-agent-core-v1</div>
                    </div>
                    
                    <!-- Terminal Body (Tech Grid) -->
                    <div class="p-8 md:p-10 h-[380px] tech-grid mono text-xs md:text-sm flex flex-col justify-start overflow-y-auto" id="terminal-engine">
                        <!-- Command outputs will be injected here via JS -->
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Command Modes -->
    <section class="py-32 bg-ghost px-6 border-t border-black/5">
